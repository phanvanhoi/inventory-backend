# ==========================================
# HangFashion Inventory — Environment Config
# Copy file này thành .env và điền giá trị thật
# ==========================================

# MySQL
MYSQL_ROOT_PASSWORD=your_strong_password_here
MYSQL_DATABASE=hangfashion_inventory

# Spring Boot / Backend
SPRING_DATASOURCE_USERNAME=root
JWT_SECRET=your_jwt_secret_min_32_characters_here_change_me

# Frontend (URL cho phép gọi API — thay bằng domain thật)
CORS_ALLOWED_ORIGINS=http://your-vps-ip-or-domain
